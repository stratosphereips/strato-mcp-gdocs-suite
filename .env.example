# Required
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret

# Optional
GOOGLE_REDIRECT_URI=http://localhost:8082
# TOKEN_STORE_PATH: defaults to /tokens in Docker, ~/.config/gdocs-suite-mcp/ locally.
# Uncomment and set only if you need a custom path.
# TOKEN_STORE_PATH=~/.config/gdocs-suite-mcp/
# Default scopes grant read/write access for Docs, Sheets, Slides, plus Drive listing/search.
GOOGLE_SCOPES=https://www.googleapis.com/auth/documents,https://www.googleapis.com/auth/spreadsheets,https://www.googleapis.com/auth/presentations,https://www.googleapis.com/auth/drive.readonly
LOG_LEVEL=WARNING
